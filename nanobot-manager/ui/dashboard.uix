<template>
  <div class="root">
    <TitleBar title="">
      <div class="titlebar-left">
        <div :class="dotClass" id="dot">
          <svg width="10" height="10" viewBox="0 0 10 10">
            <circle cx="5" cy="5" r="4" fill="currentColor"/>
          </svg>
        </div>
        <label class="titlebar-title">nanobot manager</label>
