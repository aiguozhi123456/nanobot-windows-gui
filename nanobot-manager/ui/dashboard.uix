      <div class="metric">
        <label class="metric-val" id="m_uptime">{{ uptime }}</label>
        <label class="metric-label">Uptime</label>
      </div>
    </div>

    <div class="divider"></div>

    <div class="actions">
      <div id="btn_start" class="btn btn-start" :enabled="canStart">
        <svg width="12" height="12" viewBox="0 0 24 24">
