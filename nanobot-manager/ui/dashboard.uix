<window title="nanobot manager" width="380" height="520" centered="true" frameless="true" resizable="false"/>

<script>
export default {
  data() {
    return {
      status: "stopped",
      statusText: "Stopped",
      statusSub: "nanobot is not running",
      canStart: true,
      canStop: false,
      port: "18790",
      pid: "-",
      uptime: "00:00",
      autostart: false,
      nanobotPath: "",
      theme: "system",
      installed: true
    };
  },
  computed: {
    dotClass() {
      if (this.status === "running") return "dot running";
      if (this.status === "starting") return "dot starting";
      return "dot stopped";
    },
    statusClass() {
      if (this.status === "running") return "hero-status running";
      if (this.status === "starting") return "hero-status starting";
      return "hero-status stopped";
    }
  }
}
</script>

